@startuml GharBuddy_Sequence_Morning_Routine

skinparam BackgroundColor         #F8F9FA
skinparam DefaultFontName         Calibri
skinparam DefaultFontSize         11
skinparam roundcorner             12
skinparam ArrowThickness          2
skinparam sequenceArrowThickness  2
skinparam shadowing               false

skinparam actor {
    BackgroundColor  #D1FAE5
    BorderColor      #059669
    FontColor        #1E293B
}

skinparam participant {
    BackgroundColor  #DBEAFE
    BorderColor      #2563EB
    FontColor        #1E293B
}

skinparam box {
    BackgroundColor  #FFFFFF
    BorderColor      #94A3B8
}

title <size:18><b>GharBuddy - Morning Routine Automation</b></size>\n<i>Proactive Geyser Pre-Heat from Toilet Flush + Override Learning</i>

actor User as user

box "Frontend" #EFF6FF
    participant "React Client" as client
    participant "SensorSimulator" as sim
end box

box "FastAPI Backend" #F0FDF4
    participant "FastAPI Server" as server
    participant "CaregiverMonitor" as caregiver
    participant "AuthService" as auth
end box

box "Context Engine" #FFF7ED
    participant "RoutinePredictor\n(LSTM / ONNX)" as lstm
    participant "IndianCalendar" as calendar
end box

box "AI Brain" #FDF4FF
    participant "VectorStoreService\n(pgvector RAG)" as vector
    participant "BedrockService\n(Claude 3.5)" as bedrock
end box

box "Infrastructure" #FFF1F2
    participant "PostgreSQL DB" as db
    participant "Twilio WhatsApp" as twilio
    participant "IoT Core" as iot
end box

== Authentication ==
user -> client : Login with credentials
client -> server : POST /api/auth/login
server -> auth : validateCredentials()
auth -> db : SELECT Users WHERE username=admin
db --> auth : user record
auth --> server : JWT token (HS256, 24h TTL)
server --> client : { access_token, role: "admin" }

== Morning Sensor Trigger (06:06 AM) ==
user -> sim : Trigger Toilet Flush sensor
sim -> client : Fire toiletFlush event
client -> server : POST /api/sensors/trigger\n{ sensorId: "toiletFlush" }\nAuthorization: Bearer <token>
activate server

server -> caregiver : recordMotionEvent("toiletFlush", "06:06:00")
note right of caregiver
    Morning window 5-10 AM MATCHED
    morningMotionDetected = true
    alertFired = false
end note

server -> calendar : isFastingDay() / getFestivalName()
calendar --> server : { isFasting: false, festival: null }

server -> lstm : predictNextAction(eventHistory)
activate lstm
lstm -> lstm : Run ONNX LSTM model\n30-day event sequence
lstm --> server : { predictedAction: "turnOnGeyser",\n  confidence: 0.94 }
deactivate lstm

server -> vector : querySimilarRules("Morning toilet flush 06:06")
activate vector
vector -> db : pgvector cosine similarity query
db --> vector : No override matching
vector --> server : ragContext: []
deactivate vector

server -> bedrock : generateReasoning(situationPacket)
activate bedrock
note right of bedrock
    Packet includes:
    - time: 06:06 weekday
    - predictedAction: turnOnGeyser (0.94)
    - ragContext: [] no overrides
    - isFasting: false
    - powerStatus: GRID
end note
bedrock --> server : { shouldExecute: true,\n  actionId: "turnOnGeyser",\n  confidence: 0.94,\n  explanationHindi: "Geyser on",\n  energySavedWh: 0 }
deactivate bedrock

server -> db : UPDATE Devices SET status="ON" WHERE deviceId="geyser"
server -> iot : PutThingShadow(geyser ON)
iot --> server : Shadow acknowledged
server -> twilio : sendWhatsApp(Hindi geyser alert)
twilio --> user : WhatsApp alert delivered
server -> client : broadcastSnapshot() via WebSocket
client --> user : Digital Twin updates - Geyser ON
deactivate server

== User Override - Rule Learning ==
user -> client : Click [Decline] on Reasoning Panel
client -> server : POST /api/actions/override\n{ actionId: "turnOnGeyser", approve: false }
activate server

server -> bedrock : generatePreferenceRule(decline context)
activate bedrock
bedrock --> server : "Never turn on Geyser before 06:30 on weekdays"
deactivate bedrock

server -> vector : addRule(content, category: "override")
activate vector
vector -> db : INSERT INTO VectorIndex (content, vector, category)
db --> vector : Insert success ruleId: 42
vector --> server : { ruleId: 42, saved: true }
deactivate vector

server --> client : { override_saved: true, ruleId: 42 }
client --> user : Preference saved - won't auto-execute before 06:30
deactivate server

@enduml
