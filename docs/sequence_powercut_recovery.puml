@startuml GharBuddy_Sequence_PowerCut_Recovery

skinparam BackgroundColor         #F8F9FA
skinparam DefaultFontName         Calibri
skinparam DefaultFontSize         11
skinparam roundcorner             12
skinparam ArrowThickness          2
skinparam sequenceArrowThickness  2
skinparam shadowing               false

skinparam actor {
    BackgroundColor  #FEF3C7
    BorderColor      #D97706
    FontColor        #1E293B
}

skinparam participant {
    BackgroundColor  #DBEAFE
    BorderColor      #2563EB
    FontColor        #1E293B
}

skinparam box {
    BackgroundColor  #FFFFFF
    BorderColor      #94A3B8
}

title <size:18><b>GharBuddy - Power-Cut Recovery Mode</b></size>\n<i>Inverter Pre-Charge and Load Shedding Prediction</i>

actor "Household Member" as user

box "Frontend" #EFF6FF
    participant "React Client" as client
    participant "Energy Tracker" as energyUI
end box

box "FastAPI Backend" #F0FDF4
    participant "FastAPI Server" as server
end box

box "Context Engine" #FFF7ED
    participant "LoadSheddingCalendar" as loadshed
    participant "RoutinePredictor" as lstm
    participant "IndianCalendar" as calendar
end box

box "AI Brain" #FDF4FF
    participant "BedrockService\n(Claude 3.5)" as bedrock
    participant "VectorStoreService" as vector
end box

box "Infrastructure" #FFF1F2
    participant "PostgreSQL DB" as db
    participant "Twilio WhatsApp" as twilio
    participant "IoT Core" as iot
end box

== 6:15 PM - Pre-Cut Risk Assessment ==
user -> client : Time warp to 18:15:00
client -> server : POST /api/settings/update\n{ simulatedTime: "18:15:00" }
activate server

server -> loadshed : getRiskScore("18:15:00", currentDate)
activate loadshed
loadshed -> loadshed : Time 18:15 in high-risk window MATCHED
loadshed --> server : { riskScore: 0.87, nextCutStart: 18.5,\n  shouldPrecharge: true,\n  recommendation: "precharge_inverter" }
deactivate loadshed

server -> calendar : isFastingDay()
calendar --> server : { isFasting: false }

server -> lstm : predictNextAction(powerCutRiskHigh)
activate lstm
lstm --> server : { predictedAction: "prechargeInverter",\n  confidence: 0.88 }
deactivate lstm

server -> vector : querySimilarRules("Power cut risk high 6:15 PM")
activate vector
vector -> db : pgvector cosine similarity query
db --> vector : Matching rule: "On high power-cut risk,\n precharge inverter and dim lights"\n similarity: 0.91
vector --> server : ragContext: [inverter rule match]
deactivate vector

server -> bedrock : generateReasoning({\n  event: "powerCutRiskHigh",\n  riskScore: 0.87,\n  predictedAction: "prechargeInverter",\n  ragContext: [inverter rule]\n})
activate bedrock
bedrock --> server : { shouldExecute: true,\n  action: "prechargeInverter",\n  confidence: 0.91,\n  additionalActions: ["dimLivingRoomLights"],\n  reason: "Power cut probability 87%",\n  explanationHindi: "Inverter charging",\n  energySavedWh: 280 }
deactivate bedrock

server -> iot : PutThingShadow(inverterCharging=true)
iot --> server : Acknowledged
server -> db : UPDATE Devices SET status="CHARGING" WHERE deviceId="inverter"
server -> db : UPDATE EnergyStats SET inverterCharge=85, peakPowerAvoidedW=1200
server -> twilio : sendWhatsApp("Power cut 87% likely - Inverter charging started")
twilio --> user : WhatsApp alert delivered
server -> client : broadcastSnapshot()
client -> energyUI : Inverter: CHARGING | Risk: HIGH (87%) | Saving: Rs.280
energyUI --> user : Dashboard shows load-shedding alert
deactivate server

== 6:35 PM - Power Cuts ==
client -> server : POST /api/settings/update { powerStatus: "INVERTER" }
activate server
server -> db : UPDATE SystemState SET powerStatus="INVERTER"
server -> client : broadcastSnapshot() powerStatus: INVERTER
client --> user : Digital Twin shows INVERTER mode
deactivate server

== 7:30 PM - Power Restored ==
client -> server : POST /api/settings/update { powerStatus: "GRID" }
activate server
server -> db : UPDATE SystemState SET powerStatus="GRID"
server -> twilio : sendWhatsApp("Power restored - Inverter charging stopped")
twilio --> user : WhatsApp restoration alert
server -> client : broadcastSnapshot()
client --> user : Dashboard updates - GRID mode restored
deactivate server

@enduml
