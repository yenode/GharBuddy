@startuml GharBuddy_System_Architecture

skinparam BackgroundColor         #F8F9FA
skinparam DefaultFontName         Calibri
skinparam DefaultFontSize         12
skinparam roundcorner             12
skinparam ArrowColor              #475569
skinparam ArrowThickness          2
skinparam shadowing               false

skinparam package {
    BackgroundColor    #FFFFFF
    BorderColor        #94A3B8
    BorderThickness    2
    FontColor          #1E293B
    FontStyle          bold
}

skinparam component {
    BackgroundColor    #FFFFFF
    BorderColor        #64748B
    FontColor          #1E293B
    BorderThickness    1
}

skinparam database {
    BackgroundColor    #EDE9FE
    BorderColor        #7C3AED
    FontColor          #1E293B
}

title <size:18><b>GharBuddy — System Architecture</b></size>\n<i>Context-Aware Proactive Smart Home for Indian Households</i>

' ─────────────────────────────────────────────
' PRESENTATION LAYER
' ─────────────────────────────────────────────
package "Presentation Layer  (React SPA)" as PRES #D1FAE5 {
    [React App] as react
    [SVG 2D Digital Twin] as twin
    [Reasoning Panel] as reasoning
    [Voice Widget] as voice
    [Energy Tracker] as energy
    [WhatsApp Mock Panel] as wamock
    [Sensor Simulator] as sim
}

' ─────────────────────────────────────────────
' API GATEWAY LAYER
' ─────────────────────────────────────────────
package "API Gateway  (FastAPI / Python)" as API #DBEAFE {
    [REST Endpoints] as rest
    [WebSocket Broadcast] as ws
    [AuthService JWT] as auth
    [DeviceRouter] as device
    [EnergyRouter] as energyrouter
    [VoiceRouter Whisper ASR] as voicerouter
}

' ─────────────────────────────────────────────
' CONTEXT & ROUTINE ENGINE
' ─────────────────────────────────────────────
package "Context & Routine Engine" as CTX #FEE2E2 {
    [RoutinePredictor LSTM+ONNX] as lstm
    [IndianCalendar Festivals] as calendar
    [CaregiverMonitor] as caregiver
    [LoadSheddingCalendar] as loadshed
}

' ─────────────────────────────────────────────
' AI & SEMANTIC LAYER
' ─────────────────────────────────────────────
package "AI & Semantic Store  (AWS Bedrock)" as AI #FEF3C7 {
    [BedrockService Claude 3.5] as bedrock
    [VectorStoreService pgvector] as vector
    [TitanEmbeddings 1536-dim] as titan
    [EmbeddingCache MD5] as emcache
    [GeminiRedirect Fallback] as gemini
}

' ─────────────────────────────────────────────
' INFRA / DATA LAYER
' ─────────────────────────────────────────────
package "Infrastructure & Data" as INFRA #F3E8FF {
    database "PostgreSQL + pgvector\n(Devices / EventLogs / VectorIndex)" as db
    [Twilio WhatsApp API] as twilio
    [AWS IoT Core Device Shadows] as iotcore
    [Neon DB / AWS RDS] as rds
}

' ─────────────────────────────────────────────
' RELATIONSHIPS
' ─────────────────────────────────────────────

' Presentation ↔ API
react -[#0EA5E9,thickness=2]-> rest      : HTTP REST
react -[#0EA5E9,thickness=2]-> ws        : WebSocket (real-time)
ws    -[#0EA5E9]--> react                : State broadcast
voice -[#0EA5E9]-> voicerouter           : Multipart audio
sim   -[#0EA5E9]-> rest                  : Sensor trigger events

' API → Context Engine
rest  -[#4F46E5,thickness=2]-> lstm      : predictNextAction
rest  -[#4F46E5]-> calendar              : isFasting / getFestival
rest  -[#4F46E5]-> caregiver             : recordMotionEvent
rest  -[#4F46E5]-> loadshed              : getRiskScore
device -[#4F46E5]-> db                  : Toggle / read devices
energyrouter -[#4F46E5]-> db            : Read / update EnergyStats

' API → AI Layer
rest -[#7C3AED,thickness=2]-> bedrock   : generateReasoning
bedrock -[#7C3AED]-> vector             : querySimilarRules
bedrock -[#7C3AED,dashed]-> gemini      : Fallback (no Bedrock creds)
vector -[#7C3AED]-> titan               : embedText (new rules)
vector -[#7C3AED]-> emcache             : Cache check MD5
emcache -[#7C3AED]-> db                 : Read / Write EmbeddingCache
vector -[#7C3AED]-> db                  : pgvector cosine similarity

' API → Infra
rest -[#059669,thickness=2]-> db        : Event logs / device state
rest -[#059669]-> twilio                : Hindi WhatsApp notification
rest -[#059669]-> iotcore               : IoT device shadow command
db   -[#059669]-> rds                   : Hosted on Neon / RDS

@enduml
