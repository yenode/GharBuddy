{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gharbuddy-api.onrender.com/api/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://gharbuddy-api.onrender.com/ws"
    }
  ],
  "env": {
    "VITE_API_URL": "https://gharbuddy-api.onrender.com"
  }
}
