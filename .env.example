# GharBuddy Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials

# --- PostgreSQL Configuration ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=gharbuddy

# --- AWS Bedrock & IAM Credentials ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# --- Optional Twilio Integration (WhatsApp Alerts) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=whatsapp:+14155238886
USER_PHONE_NUMBER=whatsapp:+919876543210

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-random-32-char-secret
